<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stream Panel</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="sidebar">

    <h2>🎥 Stream Panel</h2>

    <ul>

        <li>🏠 Dashboard</li>
        <li>🎬 Video Manager</li>
        <li>📃 Playlist</li>
        <li>🖼 Overlay</li>
        <li>📝 Running Text</li>
        <li>⚙ Stream</li>
        <li>🔧 Settings</li>

    </ul>

</div>

<div class="content">

    <h1>Dashboard</h1>

    <div class="cards">

        <div class="card">
            <h3>Status</h3>
            <p>🟢 Online</p>
        </div>

        <div class="card">
            <h3>Video</h3>
            <p>Belum ada</p>
        </div>

        <div class="card">
            <h3>Playlist</h3>
            <p>0 Video</p>
        </div>

        <div class="card">
            <h3>Stream</h3>
            <p>Offline</p>
        </div>

    </div>

</div>

</body>
</html>
